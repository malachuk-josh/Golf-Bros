# Upstash Redis (REST) — used to store your scorecard history.
# When you connect an Upstash store to the project on Vercel, these are added
# automatically. The app accepts EITHER the Upstash-native names OR the Vercel
# KV-style names below. Locally, copy this file to `.env.local` and fill in one pair.

# Upstash-native:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OR Vercel KV-style (also accepted):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
